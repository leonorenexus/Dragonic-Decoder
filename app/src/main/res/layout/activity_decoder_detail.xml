<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/cyber_black">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:background="@color/cyber_black_deep">

        <ImageView
            android:id="@+id/iv_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_back"
            android:padding="10dp"
            android:contentDescription="Back"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/tv_decoder_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="BASE64 DECODE"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"/>

        <ImageView
            android:id="@+id/iv_bookmark"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_star"
            android:alpha="0.5"
            android:layout_marginEnd="16dp"
            android:contentDescription="Bookmark"
            android:clickable="true"
            android:focusable="true"/>

        <ImageView
            android:id="@+id/iv_more"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_more_vert"
            android:contentDescription="More"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider"/>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- INPUT Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_neon_card"
                android:padding="14dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="INPUT"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:letterSpacing="0.3"/>

                    <TextView
                        android:id="@+id/tv_decoder_type_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DECODE:"
                        android:textColor="@color/neon_blue"
                        android:textSize="10sp"
                        android:background="@drawable/bg_badge_running"
                        android:paddingStart="6dp"
                        android:paddingEnd="6dp"
                        android:paddingTop="2dp"
                        android:paddingBottom="2dp"/>

                </LinearLayout>

                <EditText
                    android:id="@+id/et_decoder_input"
                    android:layout_width="match_parent"
                    android:layout_height="130dp"
                    android:background="@drawable/bg_input_field"
                    android:gravity="top|start"
                    android:hint="Enter encoded text here…"
                    android:textColorHint="@color/text_tertiary"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:fontFamily="monospace"
                    android:padding="12dp"
                    android:inputType="textMultiLine"
                    android:scrollbars="vertical"/>

                <!-- Action Icons Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="end"
                    android:layout_marginTop="8dp">

                    <ImageView
                        android:id="@+id/iv_paste_input"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_paste"
                        android:background="@drawable/bg_quick_tool"
                        android:padding="6dp"
                        android:layout_marginEnd="8dp"
                        android:contentDescription="Paste"
                        android:clickable="true"
                        android:focusable="true"/>

                    <ImageView
                        android:id="@+id/iv_clear_input"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_delete"
                        android:background="@drawable/bg_quick_tool"
                        android:padding="6dp"
                        android:layout_marginEnd="8dp"
                        android:contentDescription="Clear"
                        android:clickable="true"
                        android:focusable="true"/>

                    <ImageView
                        android:id="@+id/iv_upload_input"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_upload"
                        android:background="@drawable/bg_quick_tool"
                        android:padding="6dp"
                        android:contentDescription="Upload"
                        android:clickable="true"
                        android:focusable="true"/>

                </LinearLayout>

            </LinearLayout>

            <!-- Mode Selector (Encode/Decode) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_neon_card"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/tv_mode_decode"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="DECODE"
                    android:textColor="@color/cyber_black"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@drawable/bg_decode_button"
                    android:letterSpacing="0.1"
                    android:clickable="true"
                    android:focusable="true"/>

                <TextView
                    android:id="@+id/tv_mode_encode"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="ENCODE"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:letterSpacing="0.1"
                    android:clickable="true"
                    android:focusable="true"/>

            </LinearLayout>

            <!-- OUTPUT Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_neon_card"
                android:padding="14dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="OUTPUT"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:letterSpacing="0.3"/>

                    <TextView
                        android:id="@+id/tv_output_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DECODED"
                        android:textColor="@color/status_success"
                        android:textSize="10sp"
                        android:background="@drawable/bg_badge_success"
                        android:paddingStart="6dp"
                        android:paddingEnd="6dp"
                        android:paddingTop="2dp"
                        android:paddingBottom="2dp"
                        android:visibility="gone"/>

                </LinearLayout>

                <TextView
                    android:id="@+id/tv_output"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="90dp"
                    android:background="@drawable/bg_input_field"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:fontFamily="monospace"
                    android:padding="12dp"
                    android:hint="Result will appear here…"
                    android:textColorHint="@color/text_tertiary"
                    android:textIsSelectable="true"/>

                <!-- Action Buttons Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <Button
                        android:id="@+id/btn_copy_result"
                        android:layout_width="0dp"
                        android:layout_height="38dp"
                        android:layout_weight="1"
                        android:text="⊕ COPY"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:background="@drawable/bg_button_outlined"
                        android:layout_marginEnd="5dp"/>

                    <Button
                        android:id="@+id/btn_share_result"
                        android:layout_width="0dp"
                        android:layout_height="38dp"
                        android:layout_weight="1"
                        android:text="↗ SHARE"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:background="@drawable/bg_button_outlined"
                        android:layout_marginStart="5dp"
                        android:layout_marginEnd="5dp"/>

                    <Button
                        android:id="@+id/btn_save_result"
                        android:layout_width="0dp"
                        android:layout_height="38dp"
                        android:layout_weight="1"
                        android:text="↓ SAVE"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:background="@drawable/bg_button_outlined"
                        android:layout_marginStart="5dp"/>

                </LinearLayout>

            </LinearLayout>

            <!-- INFORMATION Card -->
            <LinearLayout
                android:id="@+id/card_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_neon_card"
                android:padding="14dp"
                android:layout_marginBottom="24dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="INFORMATION"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:letterSpacing="0.3"/>

                    <ImageView
                        android:id="@+id/iv_close_info"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_delete"
                        android:alpha="0.4"
                        android:contentDescription="Close"
                        android:clickable="true"
                        android:focusable="true"/>

                </LinearLayout>

                <!-- Encoding row -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="6dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="Encoding" android:textColor="@color/text_secondary" android:textSize="12sp"/>
                    <TextView android:id="@+id/tv_info_encoding" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="-" android:textColor="@color/text_primary" android:textSize="12sp"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" android:layout_marginBottom="6dp"/>

                <!-- Decoded Chars row -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="6dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="Decoded Characters" android:textColor="@color/text_secondary" android:textSize="12sp"/>
                    <TextView android:id="@+id/tv_info_chars" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="-" android:textColor="@color/text_primary" android:textSize="12sp"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" android:layout_marginBottom="6dp"/>

                <!-- Time row -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="Time" android:textColor="@color/text_secondary" android:textSize="12sp"/>
                    <TextView android:id="@+id/tv_info_time" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="-" android:textColor="@color/neon_blue" android:textSize="12sp"/>
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>
