<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/cyber_black">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="@color/cyber_black_deep">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="ANALYZER"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"/>

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_more_vert"
            android:contentDescription="More"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider"/>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- FILE ANALYSIS Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_neon_card"
                android:padding="14dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="FILE ANALYSIS"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:letterSpacing="0.3"/>

                    <ImageView
                        android:id="@+id/iv_close_analysis"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_delete"
                        android:alpha="0.5"
                        android:contentDescription="Close"/>

                </LinearLayout>

                <!-- Upload Area -->
                <LinearLayout
                    android:id="@+id/ll_upload_area"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_file_item"
                    android:padding="12dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_file"
                        android:background="@drawable/bg_quick_tool"
                        android:padding="7dp"
                        android:contentDescription="File"/>

                    <LinearLayout
                        android:id="@+id/ll_file_info"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:id="@+id/tv_file_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tap to select a file"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/tv_file_path"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Upload any file to analyze encoding"
                            android:textColor="@color/text_tertiary"
                            android:textSize="10sp"
                            android:maxLines="1"
                            android:ellipsize="middle"
                            android:layout_marginTop="3dp"/>

                        <TextView
                            android:id="@+id/tv_file_size"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="@color/text_tertiary"
                            android:textSize="10sp"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_upload"
                        android:contentDescription="Upload"/>

                </LinearLayout>

            </LinearLayout>

            <!-- DETECTION RESULT Card -->
            <LinearLayout
                android:id="@+id/card_detection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_neon_card"
                android:padding="14dp"
                android:layout_marginBottom="12dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DETECTION RESULT"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:letterSpacing="0.3"
                    android:layout_marginBottom="12dp"/>

                <!-- File Type Row -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                    <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/ic_file"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="File Type" android:textColor="@color/text_secondary" android:textSize="12sp" android:layout_marginStart="8dp"/>
                    <TextView android:id="@+id/tv_file_type" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Text File" android:textColor="@color/text_primary" android:textSize="12sp"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" android:layout_marginBottom="8dp"/>

                <!-- Encoding Row -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                    <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/ic_decode"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="Encoding" android:textColor="@color/text_secondary" android:textSize="12sp" android:layout_marginStart="8dp"/>
                    <TextView android:id="@+id/tv_detected_encoding" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="-" android:textColor="@color/neon_blue" android:textSize="12sp"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" android:layout_marginBottom="8dp"/>

                <!-- Possible Type -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                    <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/ic_search"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="Possible Type" android:textColor="@color/text_secondary" android:textSize="12sp" android:layout_marginStart="8dp"/>
                    <TextView android:id="@+id/tv_possible_type" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="-" android:textColor="@color/text_primary" android:textSize="12sp"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" android:layout_marginBottom="8dp"/>

                <!-- Entropy -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                    <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/ic_analyzer"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="Entropy" android:textColor="@color/text_secondary" android:textSize="12sp" android:layout_marginStart="8dp"/>
                    <TextView android:id="@+id/tv_entropy" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="-" android:textColor="@color/text_primary" android:textSize="12sp"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" android:layout_marginBottom="8dp"/>

                <!-- Lines -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                    <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/ic_file"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="Lines" android:textColor="@color/text_secondary" android:textSize="12sp" android:layout_marginStart="8dp"/>
                    <TextView android:id="@+id/tv_line_count" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="-" android:textColor="@color/text_primary" android:textSize="12sp"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" android:layout_marginBottom="8dp"/>

                <!-- Characters -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                    <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/ic_file"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="Characters" android:textColor="@color/text_secondary" android:textSize="12sp" android:layout_marginStart="8dp"/>
                    <TextView android:id="@+id/tv_char_count" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="-" android:textColor="@color/text_primary" android:textSize="12sp"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" android:layout_marginBottom="8dp"/>

                <!-- Recommendation -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/ic_star"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="Recommendation" android:textColor="@color/text_secondary" android:textSize="12sp" android:layout_marginStart="8dp"/>
                    <TextView android:id="@+id/tv_recommendation" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="-" android:textColor="@color/neon_blue" android:textSize="12sp"/>
                </LinearLayout>

            </LinearLayout>

            <!-- CONTENT PREVIEW Card -->
            <LinearLayout
                android:id="@+id/card_preview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_neon_card_glow"
                android:padding="14dp"
                android:layout_marginBottom="12dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CONTENT PREVIEW"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:letterSpacing="0.3"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:id="@+id/tv_content_preview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/text_primary"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:maxLines="8"
                    android:ellipsize="end"
                    android:layout_marginBottom="12dp"/>

                <Button
                    android:id="@+id/btn_decode_file"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="▶  DECODE THIS FILE"
                    android:textColor="@color/cyber_black"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_decode_button"
                    android:letterSpacing="0.1"/>

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>
