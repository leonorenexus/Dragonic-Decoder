<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cyber_black_deep">

    <!-- Animated grid background lines (simulated via views) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#0D2A40"
        android:layout_marginTop="100dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#0D2A40"
        android:layout_marginTop="200dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#0D2A40"
        android:layout_marginTop="300dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#0D2A40"
        android:layout_marginTop="500dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#0D2A40"
        android:layout_marginTop="650dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Vertical grid lines -->
    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="#0D2A40"
        android:layout_marginStart="80dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="#0D2A40"
        android:layout_marginStart="200dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="#0D2A40"
        android:layout_marginEnd="80dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Center Logo and Title -->
    <LinearLayout
        android:id="@+id/ll_splash_center"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Dragon Icon -->
        <ImageView
            android:id="@+id/iv_dragon_logo"
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:src="@drawable/ic_dragon_logo"
            android:contentDescription="Dragon Logo"/>

        <!-- App Name -->
        <TextView
            android:id="@+id/tv_app_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DRAGONIC"
            android:textColor="#FFFFFF"
            android:textSize="36sp"
            android:textStyle="bold"
            android:letterSpacing="0.3"
            android:layout_marginTop="16dp"
            android:fontFamily="sans-serif-condensed"/>

        <TextView
            android:id="@+id/tv_decoder"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DECODER"
            android:textColor="@color/neon_blue"
            android:textSize="28sp"
            android:textStyle="bold"
            android:letterSpacing="0.4"
            android:fontFamily="sans-serif-condensed"/>

        <TextView
            android:id="@+id/tv_tagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CYBERPUNK DECODE ENGINE"
            android:textColor="@color/text_tertiary"
            android:textSize="10sp"
            android:letterSpacing="0.3"
            android:layout_marginTop="8dp"/>

    </LinearLayout>

    <!-- Loading bar at bottom -->
    <LinearLayout
        android:id="@+id/ll_loading"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingBottom="60dp"
        android:paddingStart="48dp"
        android:paddingEnd="48dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LOADING..."
            android:textColor="@color/text_tertiary"
            android:textSize="10sp"
            android:letterSpacing="0.2"
            android:layout_marginBottom="12dp"/>

        <ProgressBar
            android:id="@+id/progress_loading"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:progressTint="@color/neon_blue"
            android:progressBackgroundTint="@color/border_neon"
            android:indeterminate="true"/>

    </LinearLayout>

    <!-- Corner decorations -->
    <View
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:background="@color/transparent"
        android:layout_margin="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <View
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:background="@color/transparent"
        android:layout_margin="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
