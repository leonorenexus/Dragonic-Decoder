<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/bg_file_item"
    android:padding="12dp"
    android:layout_marginBottom="8dp"
    android:clickable="true"
    android:focusable="true">

    <!-- File Type Icon -->
    <LinearLayout
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:gravity="center"
        android:background="@drawable/bg_quick_tool">

        <ImageView
            android:id="@+id/iv_file_icon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_file"
            android:contentDescription="File"/>

    </LinearLayout>

    <!-- File Info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <TextView
            android:id="@+id/tv_file_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="decoded_message.txt"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="3dp">

            <TextView
                android:id="@+id/tv_file_size"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2.45 KB"
                android:textColor="@color/text_tertiary"
                android:textSize="10sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" · "
                android:textColor="@color/text_tertiary"
                android:textSize="10sp"/>

            <TextView
                android:id="@+id/tv_file_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2 menit yang lalu"
                android:textColor="@color/text_tertiary"
                android:textSize="10sp"/>

        </LinearLayout>

    </LinearLayout>

    <!-- Actions -->
    <ImageView
        android:id="@+id/iv_download"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_downloads"
        android:background="@drawable/bg_quick_tool"
        android:padding="8dp"
        android:layout_marginEnd="6dp"
        android:contentDescription="Download"
        android:clickable="true"
        android:focusable="true"/>

    <ImageView
        android:id="@+id/iv_delete_file"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_delete"
        android:background="@drawable/bg_stat_card_failed"
        android:padding="8dp"
        android:contentDescription="Delete"
        android:clickable="true"
        android:focusable="true"/>

</LinearLayout>
