<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/bg_file_item"
    android:padding="12dp"
    android:layout_marginBottom="8dp"
    android:clickable="true"
    android:focusable="true">

    <!-- Type Icon -->
    <ImageView
        android:id="@+id/iv_decode_type_icon"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:src="@drawable/ic_decode"
        android:background="@drawable/bg_quick_tool"
        android:padding="7dp"
        android:contentDescription="Type"/>

    <!-- Info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <TextView
            android:id="@+id/tv_history_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Base64 Decode"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tv_history_preview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hello, Dragonic Decoder!..."
            android:textColor="@color/text_tertiary"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginTop="2dp"/>

        <TextView
            android:id="@+id/tv_history_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2 menit yang lalu"
            android:textColor="@color/text_tertiary"
            android:textSize="10sp"
            android:layout_marginTop="4dp"/>

    </LinearLayout>

    <!-- Status Badge -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_marginStart="8dp">

        <TextView
            android:id="@+id/tv_history_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SUCCESS"
            android:textColor="@color/status_success"
            android:textSize="9sp"
            android:background="@drawable/bg_badge_success"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"/>

        <TextView
            android:id="@+id/tv_history_duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="120 ms"
            android:textColor="@color/text_tertiary"
            android:textSize="10sp"
            android:layout_marginTop="6dp"/>

    </LinearLayout>

</LinearLayout>
